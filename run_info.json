{
    "dataset": "CarPrice_Assignment.csv",
    "shape": [
        10781,
        9
    ],
    "target": "price",
    "split": {
        "train": 0.7,
        "validation": 0.15,
        "test": 0.15
    },
    "random_state": 42,
    "model": "Ridge(alpha=1.0)",
    "preprocessing": {
        "numeric": [
            "median imputer",
            "standard scaler"
        ],
        "categorical": [
            "most_frequent imputer",
            "onehot (handle_unknown=ignore)"
        ]
    },
    "metrics": {
        "validation": {
            "MAE": 1620.6221671141782,
            "RMSE": 2782.968884568833,
            "R2": 0.9410916241369086
        },
        "test": {
            "MAE": 1540.1765350918747,
            "RMSE": 2427.7567448106947,
            "R2": 0.9533087814812493
        }
    }
}